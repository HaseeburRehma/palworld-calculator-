# Base URL for the Pal data scraper. Pick ONE community-maintained source.
# Recommended candidates (review before choosing — terms / robots may change):
#   https://paldb.cc
#   https://palworld.gg
#   https://palworld.fandom.com
# Set the one you want to use; the scraper reads this at run time.
PAL_DATA_SOURCE=

# Optional: contact email used in the scraper User-Agent (be a polite citizen of the web).
SCRAPER_CONTACT_EMAIL=
