{
  "name": "palworld-breeding-calculator",
  "version": "0.1.0",
  "private": true,
  "description": "Palworld breeding calculator — pick two parents, see the child. Phase 1.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "scrape": "pnpm scrape:pals && pnpm scrape:combos && pnpm scrape:passives && pnpm build:reverse-index",
    "scrape:pals": "tsx scripts/scrape-pals.ts",
    "scrape:combos": "tsx scripts/scrape-combos.ts",
    "scrape:passives": "tsx scripts/scrape-passives.ts",
    "build:reverse-index": "tsx scripts/build-reverse-index.ts",
    "verify-mappings": "tsx scripts/verify-mappings.ts",
    "download:images": "tsx scripts/download-pal-images.ts",
    "seo:audit": "tsx scripts/seo-audit.ts",
    "lighthouse": "tsx scripts/lighthouse-ci.ts",
    "a11y": "tsx scripts/a11y-ci.ts",
    "test:ld": "tsx scripts/validate-ld.ts"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "lz-string": "^1.5.0",
    "next": "^14.2.5",
    "next-mdx-remote": "^4.4.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.14.10",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^14.12.3",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "unified": "^11.0.5",
    "vitest": "^2.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
